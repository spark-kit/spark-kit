# =============================================================
#  Spark .env — serveur Linux
#  Copier ce fichier vers /opt/spark/infra/.env et adapter.
#  chmod 600 .env apres edition.
# =============================================================

# --- CHANGER PAR ENVIRONNEMENT ---------------------------------
# PREPROD : SPARK_PREFIX=erp-preprod   PROD : SPARK_PREFIX=erp
SPARK_PREFIX=
SPARK_DOMAIN=
SPARK_HOST_HTTP_PORT=18080

# --- PostgreSQL (generer avec gen_secret) ----------------------
POSTGRES_ROOT_PASSWORD=
N8N_DB_PASSWORD=
NOCODB_DB_PASSWORD=

# --- n8n (openssl rand -hex 32) --------------------------------
N8N_ENCRYPTION_KEY=

# --- NocoDB (openssl rand -hex 32) -----------------------------
NC_AUTH_JWT_SECRET=

# --- Cloudflare Tunnel (remplir a l'etape 4) -------------------
SPARK_TUNNEL_ID=
SPARK_TUNNEL_CONFIG=/opt/spark/.cloudflared/config-spark.yml
CF_API_TOKEN=
CF_ZONE_ID=

# --- MCP / outillage agent (remplir apres premier acces) -------
N8N_API_KEY=
NOCODB_API_TOKEN=
N8N_MCP_AUTH_TOKEN=
